{
  "name": "@sentry/skillet",
  "version": "0.18.0",
  "description": "Create, evaluate, and iterate on agent skills",
  "type": "module",
  "bin": {
    "skillet": "./dist/cli.js"
  },
  "exports": {
    "./evals": {
      "types": "./dist/lib/evals.d.ts",
      "import": "./dist/lib/evals.js"
    }
  },
  "scripts": {
    "build": "node build.js",
    "dev": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware src/",
    "lint:fix": "oxlint --type-aware --fix src/",
    "format": "oxfmt --check src/",
    "format:fix": "oxfmt src/",
    "check": "npm run typecheck && npm run lint && npm run format"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.68.1",
    "vitest": "^3.2.4",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "references",
    "skills"
  ],
  "license": "MIT"
}
