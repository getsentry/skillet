{
  "name": "@sentry/skillet",
  "version": "1.4.0",
  "description": "Spec-driven agent skills with mechanical evals",
  "type": "module",
  "bin": {
    "skillet": "./dist/cli.js"
  },
  "scripts": {
    "build": "node build.js",
    "docs:build": "npm --prefix docs run build",
    "docs:check": "npm --prefix docs run check",
    "docs:dev": "npm --prefix docs run dev",
    "prepublishOnly": "npm run build",
    "prepare": "git config core.hooksPath .githooks",
    "dev": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint --deny-warnings src/ && ast-grep scan src/",
    "lint:fix": "oxlint --deny-warnings --fix src/",
    "format": "oxfmt --check src/",
    "format:fix": "oxfmt src/",
    "check": "npm run typecheck && npm run lint && npm run format && npm run test"
  },
  "dependencies": {
    "ai": "^6.0.225",
    "tinyrainbow": "^3.1.0",
    "vitest": "^4.1.10",
    "vitest-evals": "0.14.0",
    "yaml": "^2.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.1",
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
