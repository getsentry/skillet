---
import CopyPrompt from "@sentry/starlight-theme/components/CopyPrompt.astro";

const prompt =
  "Install the skillet-authoring skill globally from https://github.com/getsentry/skillet.";
---

<section class="skillet-setup-prompt">
  <CopyPrompt content={prompt} title="Install Skillet with your agent" open />

  <div class="skillet-setup-actions">
    <a class="skillet-setup-action skillet-setup-action-primary" href="/quickstart/">
      Get Started <span aria-hidden="true">→</span>
    </a>
    <a class="skillet-setup-action" href="https://github.com/getsentry/skillet">
      View on GitHub <span aria-hidden="true">↗</span>
    </a>
  </div>
</section>
